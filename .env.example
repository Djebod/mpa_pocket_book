# Salin file ini menjadi .env.local, lalu isi nilainya.
# JANGAN commit file .env.local ke GitHub (sudah otomatis diabaikan lewat .gitignore).

# --- Google Service Account (dibuat lewat Google Cloud Console) ---
GOOGLE_SERVICE_ACCOUNT_EMAIL=nama-service-account@nama-project.iam.gserviceaccount.com
# Private key dari file JSON kredensial, tetap dalam satu baris dengan \n literal:
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nISI_KEY_DI_SINI\n-----END PRIVATE KEY-----\n"

# --- Google Sheets untuk data (Members / Products / Activities) ---
# ID ada di URL spreadsheet: https://docs.google.com/spreadsheets/d/ID_INI/edit
GOOGLE_SHEET_ID=

# --- Google Drive folder untuk menyimpan foto hasil aktivitas ---
# ID ada di URL folder Drive: https://drive.google.com/drive/folders/ID_INI
GOOGLE_DRIVE_FOLDER_ID=

# --- OAuth2 untuk Google Drive (DISARANKAN, khusus akun Google personal) ---
# Service Account TIDAK punya kuota penyimpanan sendiri di Drive biasa,
# jadi upload foto butuh identitas dengan kuota asli: akun Google Anda
# sendiri, lewat OAuth2 refresh token. Lihat README.md bagian
# "Menyambungkan ke Google Sheets & Google Drive" untuk cara mendapatkan
# nilai-nilai ini lewat OAuth Playground.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# Jangan lupa: bagikan (Share) Google Sheet di atas ke alamat email
# GOOGLE_SERVICE_ACCOUNT_EMAIL dengan akses "Editor", supaya Service
# Account ini boleh membaca & menulis ke sana. (Folder Drive tidak perlu
# di-share ke Service Account kalau Anda memakai OAuth2 di atas — cukup
# pastikan folder itu ada di akun Google yang Anda pakai saat login di
# OAuth Playground.)
